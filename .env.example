# Homepage promotional modal. "true" = show on each homepage visit; "false" or unset = off (no other flags required).
NEXT_PUBLIC_SHOW_HOME_PROMO_MODAL=false
# Shown as “Only X spots left” in the promo modal (default 5). Decrease as seats fill; redeploy after changes.
NEXT_PUBLIC_HOME_PROMO_SPOTS_LEFT=5
